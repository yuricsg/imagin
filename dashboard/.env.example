# Backend (Hono API) base URL used by the browser and the widget.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Optional: base URL used for server-side calls (NextAuth authorize,
# getDashboardData). Falls back to NEXT_PUBLIC_API_BASE_URL when unset.
# API_BASE_URL=http://localhost:4000

# Origin that serves the embeddable widget/iframe.
NEXT_PUBLIC_WIDGET_BASE_URL=http://localhost:3000

# NextAuth (Auth.js) secret used to sign the session JWT. Required.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
