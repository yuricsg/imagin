generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Operators allowed to sign in to the dashboard. Provisioned by the admin
/// (see `npm run user:add`); there is no self-service registration.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  /// Command-palette pins (⌘K), in pin order. Per operator, synced across devices.
  pinnedCommands String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Bot {
  id                    String   @id
  name                  String
  clientId              String
  clientName            String
  status                String   @default("active")
  flowKey               String   @default("cardiology_exam_consultation")
  description           String   @default("")
  whatsappPhone         String
  buttonTexts           String[]
  examOptions           String[]
  medicalRequestOptions String[]
  consultationNeeds     String[]
  consultationDecisions String[]
  metaPixelId           String?
  metaAccessToken       String?
  metaTestEventCode     String?
  gasMeasurementId      String?
  gaApiSecret           String?
  avatarUrl             String?
  dashboardConfig       Json?
  createdAt             DateTime @default(now())

  @@map("bots")
}

model Lead {
  id                    String   @id @default(uuid())
  botId                 String
  clientId              String
  name                  String
  intent                String
  selectedExams         String[]
  medicalRequestStatus  String?
  consultationNeed      String?
  consultationDecision  String?
  phone                 String?
  email                 String?
  message               String?
  customFields          Json?
  answers               Json?
  flowMode              String   @default("legacy")
  whatsappDestinationId String?
  sessionId             String?  @unique
  status                String   @default("new")
  whatsappMessage       String
  whatsappUrl           String
  pageUrl               String?
  landingPageUrl        String?
  referrer              String?
  parentOrigin          String?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmContent            String?
  utmTerm               String?
  utmId                 String?
  fbclid                String?
  gclid                 String?
  fbp                   String?
  fbc                   String?
  gaClientId            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([botId])
  @@index([createdAt])
  @@map("leads")
}

model ChatSession {
  id                     String   @id @default(uuid())
  botId                  String
  clientId               String
  leadId                 String?  @unique
  visitorName            String?
  intent                 String?
  flowMode               String   @default("legacy")
  currentStep            String?
  answers                Json?
  source                 Json?
  openedAt               DateTime @default(now())
  lastActivityAt         DateTime @default(now())
  flowCompletedAt        DateTime?
  whatsappClickedAt      DateTime?
  appointmentRequestedAt DateTime?
  notInterestedAt        DateTime?
  convertedAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  events                 ChatEvent[]

  @@index([botId, openedAt])
  @@index([clientId, openedAt])
  @@index([lastActivityAt])
  @@map("chat_sessions")
}

model ChatEvent {
  id        String      @id @default(uuid())
  sessionId String
  botId     String
  clientId  String
  type      String
  stepId    String?
  label     String?
  value     Json?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([botId, createdAt])
  @@map("chat_events")
}
