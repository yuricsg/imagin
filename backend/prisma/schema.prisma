generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Bot {
  id                    String   @id
  name                  String
  clientId              String
  clientName            String
  status                String   @default("active")
  flowKey               String   @default("cardiology_exam_consultation")
  description           String   @default("")
  whatsappPhone         String
  buttonTexts           String[]
  examOptions           String[]
  medicalRequestOptions String[]
  consultationNeeds     String[]
  consultationDecisions String[]
  metaPixelId           String?
  metaAccessToken       String?
  metaTestEventCode     String?
  gasMeasurementId      String?
  gaApiSecret           String?
  dashboardConfig       Json?
  createdAt             DateTime @default(now())

  @@map("bots")
}

model Lead {
  id                    String   @id @default(uuid())
  botId                 String
  clientId              String
  name                  String
  intent                String
  selectedExams         String[]
  medicalRequestStatus  String?
  consultationNeed      String?
  consultationDecision  String?
  status                String   @default("new")
  whatsappMessage       String
  whatsappUrl           String
  pageUrl               String?
  landingPageUrl        String?
  referrer              String?
  parentOrigin          String?
  utmSource             String?
  utmMedium             String?
  utmCampaign           String?
  utmContent            String?
  utmTerm               String?
  utmId                 String?
  fbclid                String?
  gclid                 String?
  fbp                   String?
  fbc                   String?
  gaClientId            String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([botId])
  @@index([createdAt])
  @@map("leads")
}
