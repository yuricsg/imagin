{
  "name": "backend-imagin",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "qa:live-db": "node --import tsx src/qa/live-db-check.ts",
    "build": "npx prisma generate && tsc",
    "start": "npx prisma migrate deploy && node dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.27",
    "pg": "^8.22.0",
    "prisma": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
